<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Add New Product — BGT Market</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    
    <style>
        body {
            background-color: #f8f4ec;
            font-family: 'DM Serif Display', serif;
        }

        .navbar {
             background-color: #432f1f;
        }

        
        .navbar-brand {
            font-family: "Montserrat", sans-serif;
            color: #52b788 !important;
            font-size: 1.5rem;
            font-weight: 500;
        }
    </style>
</head>

<body>


    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/img/logo.png" alt="BGT Market Logo"
                    style="height: 50px; margin-right: 10px; object-fit: contain;">
                BGT Market
            </a>
            <div class="d-flex align-items-center">
                <span class="text-white me-3">Welcome, <strong>
                        <%= user.userName %>
                    </strong></span>
                <a href="/logout" class="btn btn-outline-light btn-sm">Log Out</a>
            </div>
        </div>
    </nav>


    <div class="container">
        <div class="card shadow-sm mx-auto" style="max-width: 600px; border-radius: 15px;">
            <div class="card-body p-4">
                <h3 class="mb-4 text-success">Add a New Discounted Product</h3>

                <form action="/market/add-product" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Product Name</label>
                        <input type="text" name="name" class="form-control" required placeholder="Ex: 1 L Fresh Milk">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Stock Quantity</label>
                        <input type="number" name="stock" class="form-control" min="1" required placeholder="Ex: 50"
                            value="<%= typeof product !== 'undefined' ? product.stock : '' %>">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="description" class="form-control" rows="2"
                            placeholder="Short information about the product condition..."></textarea>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Original Price (₺)</label>
                            <input type="number" step="0.01" name="original_price" class="form-control" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Discounted Price (₺)</label>
                            <input type="number" step="0.01" name="discounted_price" class="form-control" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Expiration Date</label>
                        <input type="date" name="expiration_date" class="form-control" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Upload Product Image</label>

                        <input type="file" name="image" class="form-control" accept="image/*" required>
                    </div>

                    <button type="submit" class="btn btn-success w-100">List Product for Sale</button>
                    <a href="/market/dashboard"
                        class="btn btn-link w-100 mt-2 text-secondary text-decoration-none">Cancel and Return to
                        Dashboard</a>
                </form>
            </div>
        </div>
    </div>

</body>

</html>