<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Cart — BGT Market</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <style>body { background-color: #f8f4ec; font-family: sans-serif; }
        .navbar-brand {
            font-family: "Montserrat", sans-serif;
            color: #52b788 !important;
            font-size: 1.5rem;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4" style="background-color: #432f1f;">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/img/logo.png" alt="BGT Market Logo"
                    style="height: 50px; margin-right: 10px; object-fit: contain;">
                BGT Market
            </a>
            <div class="ms-auto">
                <a href="/" class="btn btn-outline-light btn-sm">Home</a>
            </div>
        </div>
    </nav>

    <div class="container mb-5" id="cart-container">
        <h3 class="mb-4 fw-bold">🛒 My Cart</h3>

        <% if (items.length === 0) { %>
            <div class="alert alert-warning text-center">Your cart is empty.</div>
        <% } else { %>
            <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0" id="cartTable">
                        <thead style="background-color: #f0faf5;">
                            <tr>
                                <th class="ps-4">Product</th>
                                <th>Unit Price</th>
                                <th>Quantity</th>
                                <th>Amount</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% items.forEach(item => { %>
                                <tr id="row-<%= item.cart_id %>">
                                    <td class="ps-4">
                                        <div class="fw-bold"><%= item.name %></div>
                                        <small class="text-muted">Expires: <%= new Date(item.expiration_date).toLocaleDateString('en-US') %></small>
                                    </td>
                                    <td class="text-success fw-bold"><%= item.discounted_price %> ₺</td>
                                    
                                    
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-secondary" onclick="updateQty(<%= item.cart_id %>, 'decrease')">-</button>
                                            <span class="btn btn-light fw-bold" id="qty-<%= item.cart_id %>"><%= item.quantity %></span>
                                            <button class="btn btn-outline-secondary" onclick="updateQty(<%= item.cart_id %>, 'increase')">+</button>
                                        </div>
                                    </td>
                                    
                                    <td class="fw-bold" id="itemTotal-<%= item.cart_id %>">
                                        <%= (item.discounted_price * item.quantity).toFixed(2) %> ₺
                                    </td>
                                    
                                   
                                    <td>
                                        <button class="btn btn-sm btn-danger" onclick="removeItem(<%= item.cart_id %>)">Remove</button>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            
            <div class="d-flex justify-content-end mt-4">
                <div class="card border-0 shadow-sm p-4" style="min-width: 280px;">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Grand Total</span>
                        <span class="fs-5 fw-bold text-success" id="grandTotal"><%= total.toFixed(2) %> ₺</span>
                    </div>
                    <button onclick="checkoutCart()" class="btn btn-success w-100 fw-bold" id="checkoutBtn">✅ Complete Order</button>
                </div>
            </div>
        <% } %>
    </div>

    <!-- Toast Notification -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="ajaxToast" class="toast align-items-center text-white border-0 bg-danger" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold" id="toastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function showToast(msg, isSuccess = false) {
            const toastEl = document.getElementById('ajaxToast');
            document.getElementById('toastMessage').textContent = msg;
            toastEl.className = `toast align-items-center text-white border-0 ${isSuccess ? 'bg-success' : 'bg-danger'}`;
            new bootstrap.Toast(toastEl).show();
        }

        
        function updateQty(cartId, action) {
            fetch('/cart/update-ajax', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cartId, action })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('qty-' + cartId).textContent = data.newQuantity;
                    document.getElementById('itemTotal-' + cartId).textContent = data.itemTotal + ' ₺';
                    document.getElementById('grandTotal').textContent = data.newTotal + ' ₺';
                } else {
                    showToast(data.message);
                }
            });
        }

        
        function removeItem(cartId) {
            if(!confirm('Are you sure you want to remove this product?')) return;
            fetch('/cart/remove-ajax', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cartId })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('row-' + cartId).remove(); 
                    document.getElementById('grandTotal').textContent = data.newTotal + ' ₺';
                    if (data.cartIsEmpty) location.reload(); 
                }
            });
        }

        
        function checkoutCart() {
            const btn = document.getElementById('checkoutBtn');
            btn.disabled = true;
            btn.textContent = "Processing...";

            fetch('/cart/checkout-ajax', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                   
                    window.location.href = '/orders/' + data.orderId;
                } else {
                    showToast(data.message);
                    btn.disabled = false;
                    btn.textContent = "✅ Complete Order";
                }
            });
        }
    </script>
</body>
</html>