<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Edit — BGT Market</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: #f8f4ec;
            font-family: sans-serif;
        }

        .navbar {
            background-color: #432f1f;
        }

        .navbar-brand {
            font-family: "Montserrat", sans-serif;
            color: #52b788 !important;
            font-size: 1.5rem;
            font-weight: 500;
        }
    </style>
</head>

<body>

    
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/market/dashboard">🐞 BGT Market Panel</a>
            <div class="d-flex align-items-center">
                <span class="text-white me-3">Welcome, <strong>
                        <%= user.userName %>
                    </strong></span>
                <a href="/logout" class="btn btn-outline-light btn-sm">Log Out</a>
            </div>
        </div>
    </nav>

   
    <div class="container pb-5">
        <div class="card shadow-sm mx-auto border-0" style="max-width: 600px; border-radius: 15px;">
            <div class="card-body p-4 p-md-5">
                <h3 class="mb-4 text-primary fw-bold">✏️ Edit Product</h3>

                <form action="/market/edit-product/<%= product.id %>" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Product Name</label>
                        <input type="text" name="name" class="form-control" value="<%= product.name %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="description" class="form-control" rows="2"><%= product.description %></textarea>
                    </div>

                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Stock Quantity</label>
                        <input type="number" name="stock" class="form-control" min="0" value="<%= product.stock %>"
                            required>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Original Price (₺)</label>
                            <input type="number" step="0.01" name="original_price" class="form-control"
                                value="<%= product.original_price %>" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">Discounted Price (₺)</label>
                            <input type="number" step="0.01" name="discounted_price" class="form-control"
                                value="<%= product.discounted_price %>" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Expiration Date</label>
                        
                        <input type="date" name="expiration_date" class="form-control"
                            value="<%= new Date(product.expiration_date).toISOString().split('T')[0] %>" required>
                    </div>

                    <div class="mb-4 p-3 bg-light rounded border">
                        <label class="form-label fw-bold">Upload New Image (Optional)</label>
                        <p class="small text-muted mb-2">Leave this empty if you do not want to change the current image.
                        </p>
                        
                        <input type="file" name="image" class="form-control" accept="image/*">

                        <% if (product.image_url) { %>
                            <div class="mt-3">
                                <span class="small text-muted d-block mb-1">Current Image:</span>
                                <img src="<%= product.image_url %>" alt="Current Image"
                                    style="height: 60px; border-radius: 8px;">
                            </div>
                            <% } %>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary fw-bold py-2">Save Changes</button>
                        <a href="/market/dashboard" class="btn btn-light border text-secondary fw-bold py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>

</html>