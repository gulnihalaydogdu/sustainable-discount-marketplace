<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Verification — BGT Market</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; background-color: #f8f4ec; }
        .card { border-radius: 20px; }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="card shadow border-0 p-5" style="max-width: 450px; width: 100%;">
            
            <div class="text-center mb-4">
                <div style="font-size: 3rem;">📧</div>
                <h3 class="fw-bold mt-2" style="color: rgb(55, 23, 23);">Email Verification</h3>
                <p class="text-muted"><strong><%= email %></strong> enter the 6-digit code sent to this address.</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/verify" method="POST">
                <input type="hidden" name="email" value="<%= email %>">
                
                <div class="mb-4">
                    <input 
                        type="text" 
                        name="code" 
                        class="form-control form-control-lg text-center fw-bold" 
                        placeholder="000000"
                        maxlength="6"
                        style="font-size: 2rem; letter-spacing: 8px;"
                        autofocus
                        required>
                </div>

                <button type="submit" class="btn btn-success w-100 fw-bold py-2">Verify and Sign Up</button>
            </form>

            <div class="text-center mt-3">
                <small class="text-muted">Didn't receive the code? <a href="/register" style="color: #2d6a4f;">Try again</a></small>
            </div>
        </div>
    </div>
</body>
</html>