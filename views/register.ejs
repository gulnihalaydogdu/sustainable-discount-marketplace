<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up — Sustainable Marketplace</title>
  <link rel="stylesheet" href="/css/auth.css">
  <link
    href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
    rel="stylesheet">
</head>

<body>

  <div class="auth-page">


    <aside class="brand-panel">
      <a href="/" class="brand-logo" style="text-decoration: none; color: inherit;">
        <div class="logo-leaf">
          <div class="logo-icon"><img src="/img/logo.png" alt="BGT Market Logo"
              style="width: 55px; margin-bottom: 15px; filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.3));"></div>
          <span class="logo-name">BGT Market</span>
        </div>
      </a>

      <div class="brand-headline">
        <h1>Let's stop<br><em>waste together.</em></h1>
        <p>
          If you own a market, list your products; if you are a customer, discover discounted items.
          There is a place for everyone.
        </p>

        <div class="brand-stats">
          <div class="stat-item">
            <span class="stat-value">%40</span>
            <span class="stat-label">Average Discount</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">500+</span>
            <span class="stat-label">Active Markets</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">12K</span>
            <span class="stat-label">Users</span>
          </div>
        </div>
      </div>
    </aside>


    <main class="form-panel" style="position: relative;">
      <div class="form-container">

        <div class="form-header">
          <h2>Create Account</h2>
          <p>Already have an account? <a href="/login">Log in →</a></p>
        </div>

        <div class="auth-card">


          <% if (typeof error !=='undefined' && error) { %>
            <div class="error-alert">
              <span>⚠️</span>
              <span>
                <%= error %>
              </span>
            </div>
            <% } %>


              <div class="user-type-toggle" id="userTypeToggle">
                <button type="button" class="user-type-btn active" data-value="consumer"
                  onclick="selectUserType('consumer')">
                  <span class="type-icon">🛒</span>
                  Customer
                </button>
                <button type="button" class="user-type-btn" data-value="market" onclick="selectUserType('market')">
                  <span class="type-icon">🏪</span>
                  Market Owner
                </button>
              </div>

              <form action="/register" method="POST" novalidate>


                <input type="hidden" id="userTypeInput" name="userType"
                  value="<%= typeof oldInput !== 'undefined' && oldInput.userType ? oldInput.userType : 'consumer' %>">

                <div class="form-group">
                  <label for="email">Email</label>
                  <input type="email" id="email" name="email" placeholder="example@email.com"
                    value="<%= typeof oldInput !== 'undefined' ? (oldInput.email || '') : '' %>" required
                    autocomplete="email">
                </div>

                <div class="form-group">
                  <label for="name" id="nameLabel">Full Name</label>
                  <input type="text" id="name" name="name" placeholder="Full Name"
                    value="<%= typeof oldInput !== 'undefined' ? (oldInput.name || '') : '' %>" required
                    autocomplete="name">
                </div>

                <div class="form-group">
                  <label for="password">Password</label>
                  <input type="password" id="password" name="password" placeholder="At least 6 characters" required
                    autocomplete="new-password">
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label for="city">City</label>
                    <input type="text" id="city" name="city" placeholder="Ankara"
                      value="<%= typeof oldInput !== 'undefined' ? (oldInput.city || '') : '' %>" required>
                  </div>
                  <div class="form-group">
                    <label for="district">District</label>
                    <input type="text" id="district" name="district" placeholder="Cankaya"
                      value="<%= typeof oldInput !== 'undefined' ? (oldInput.district || '') : '' %>" required>
                  </div>
                </div>

                <button type="submit" class="btn-submit">Sign Up</button>

              </form>
        </div>

      </div>

       <div style="position: absolute; bottom: 7px; right: 7px;
       color: rgba(0, 0, 0, 0.2); font-size: 0.85rem;
        letter-spacing: 0.5px; pointer-events: none; font-style: italic; font-family: 'Montserrat', sans-serif;">
        Gulnihal Aydogdu - Tunahan Akkus - Ozum Beril Kilic
      </div>

    </main>

  </div>

  <script>

    function selectUserType(value) {
      document.getElementById('userTypeInput').value = value;

      const nameLabel = document.getElementById('nameLabel');
      const nameInput = document.getElementById('name');

      document.querySelectorAll('.user-type-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.value === value);
      });

      if (value === 'market') {
        nameLabel.textContent = 'Market Name';
        nameInput.placeholder = 'Tok Market';
      } else {
        nameLabel.textContent = 'Full Name';
        nameInput.placeholder = 'Full Name';
      }
    }


    (function () {
      const savedType = document.getElementById('userTypeInput').value || 'consumer';
      selectUserType(savedType);
    })();
  </script>

</body>

</html>