<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BGT Market — Reduce Waste, Save More</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #f8f4ec;
            font-weight: 500;
        }

        .navbar {
            background-color: #432f1f;
        }

        .navbar-brand {
            font-family: "Montserrat", sans-serif;
            color: #52b788 !important;
            font-size: 1.5rem;
        }

        .hero-section {
            background-color: #816650;
            color: white;
            padding: 60px 0;
            text-align: center;
            border-radius: 0 0 30px 30px;
            margin-bottom: 40px;
        }
    </style>
</head>

<body>


    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/img/logo.png" alt="BGT Market Logo"
                    style="height: 50px; margin-right: 10px; object-fit: contain;">
                BGT Market
            </a>
            <div class="ms-auto d-flex gap-2">
                <% if (user && user.userId) { %>
                    <span class="text-white align-self-center me-3">Hello, <strong>
                            <%= user.userName %>
                        </strong></span>
                    <% if (user.userType==='market' ) { %>
                        <a href="/market/dashboard" class="btn btn-outline-light btn-sm">My Panel</a>
                        <% } else { %>

                            <a href="/profile" class="btn btn-outline-light btn-sm">⚙️ My Profile</a>
                            <a href="/cart" class="btn btn-warning btn-sm">🛒 My Cart</a>
                            <% } %>
                                <a href="/logout" class="btn btn-outline-danger btn-sm">Log Out</a>
                                <% } else { %>
                                    <a href="/login" class="btn btn-outline-light btn-sm">Log In</a>
                                    <a href="/register" class="btn btn-success btn-sm">Sign Up</a>
                                    <% } %>
            </div>
        </div>
    </nav>


    <div class="hero-section shadow-sm">
        <div class="container">
            <h1 class="fw-bold mb-3">Fresh Products, Big Discounts</h1>
            <p class="lead mb-4">Rescue products near their expiration date, protect nature, and save money.
            </p>


            <div class="mx-auto" style="max-width: 500px;">
                <form action="/" method="GET" class="d-flex shadow-sm" style="border-radius: 10px; overflow: hidden;">
                    <input type="text" name="q" class="form-control form-control-lg border-0"
                        placeholder="Ex: Milk, Eggs, Bread..."
                        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">Search</button>
                </form>
            </div>
        </div>
    </div>


    <div class="container mb-5">


        <% if (typeof searchQuery !=='undefined' && searchQuery.trim() !=='' ) { %>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="text-success fw-bold">Search Results for "<span class="text-dark">
                        <%= searchQuery %>
                    </span>"</h3>
                <a href="/" class="btn btn-outline-secondary btn-sm">Clear Search ✖</a>
            </div>
            <% } else { %>
                <h3 class="mb-4 text-success fw-bold">Latest Discounted Products</h3>
                <% } %>

                    <% if (products.length===0) { %>
                        <div class="alert alert-warning text-center">There are no discounted products on sale right now.
                        </div>
                        <% } else { %>

                            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">

                                <% products.forEach(product=> { %>
                                    <div class="col">
                                        <div class="card h-100 shadow-sm border-0"
                                            style="border-radius: 12px; overflow: hidden;">


                                            <% if (product.image_url) { %>
                                                <img src="<%= product.image_url %>" class="card-img-top p-3"
                                                    alt="<%= product.name %>"
                                                    style="height: 180px; object-fit: contain; background-color: #ffffff;">
                                                <% } else { %>
                                                    <div class="bg-light d-flex justify-content-center align-items-center"
                                                        style="height: 180px;">No Image</div>
                                                    <% } %>

                                                        <div class="card-body d-flex flex-column">
                                                            <h6 class="fw-bold text-success">
                                                                <%= product.name %>
                                                            </h6>
                                                            <p class="small text-muted mb-2">
                                                                <%= product.description %>
                                                            </p>


                                                            <div class="mt-auto">
                                                                <div
                                                                    class="d-flex justify-content-between align-items-center mb-2">
                                                                    <span
                                                                        class="text-decoration-line-through text-danger small">
                                                                        <%= product.original_price %> ₺
                                                                    </span>
                                                                    <span class="fs-5 fw-bold text-success">
                                                                        <%= product.discounted_price %> ₺
                                                                    </span>
                                                                </div>

                                                                <span
                                                                    class="badge bg-warning text-dark mb-2 w-100 py-2">⏳
                                                                    Expires: <%= new
                                                                        Date(product.expiration_date).toLocaleDateString('en-US')
                                                                        %></span>


                                                                <% if (product.stock> 0) { %>
                                                                    <span
                                                                        class="badge bg-info text-dark mb-3 w-100 py-1">In
                                                                        stock: <%= product.stock %> items
                                                                            available</span>
                                                                    <button class="btn btn-success w-100"
                                                                        onclick="addToCart(<%= product.id %>)">Add to
                                                                        Cart</button>
                                                                    <% } else { %>
                                                                        <span
                                                                            class="badge bg-danger mb-3 w-100 py-1">Sold
                                                                            Out</span>
                                                                        <button
                                                                            class="btn btn-secondary w-100 disabled">Sold
                                                                            Out</button>
                                                                        <% } %>
                                                            </div>

                                                        </div>
                                        </div>
                                    </div>
                                    <% }) %>

                            </div>

                            <% if (totalPages> 1) { %>
                                <nav aria-label="Sayfalar" class="mt-5">
                                    <ul class="pagination justify-content-center">


                                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                            <a class="page-link text-success"
                                                href="/?page=<%= currentPage - 1 %><%= searchQuery ? '&q=' + searchQuery : '' %>">Previous</a>
                                        </li>


                                        <% for(let i=1; i <=totalPages; i++) { %>
                                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                <a class="page-link <%= currentPage === i ? 'bg-success border-success text-white' : 'text-success' %>"
                                                    href="/?page=<%= i %><%= searchQuery ? '&q=' + searchQuery : '' %>">
                                                    <%= i %>
                                                </a>
                                            </li>
                                            <% } %>


                                                <li
                                                    class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                                    <a class="page-link text-success"
                                                        href="/?page=<%= currentPage + 1 %><%= searchQuery ? '&q=' + searchQuery : '' %>">Next</a>
                                                </li>

                                    </ul>
                                </nav>
                                <% } %>
                                    <% } %>
    </div>

    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        <div id="cartToast" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold" id="toastMessage">Product added to cart!</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function addToCart(productId) {
            fetch('/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ product_id: productId })
            })
                .then(res => res.json())
                .then(data => {
                    const toastEl = document.getElementById('cartToast');
                    const toastMsg = document.getElementById('toastMessage');

                    if (data.success) {
                        toastEl.classList.remove('bg-danger');
                        toastEl.classList.add('bg-success');
                        toastMsg.textContent = '✅ ' + data.message;
                    } else {
                        toastEl.classList.remove('bg-success');
                        toastEl.classList.add('bg-danger');
                        toastMsg.textContent = '⚠️ ' + data.message;
                    }

                    new bootstrap.Toast(toastEl, { delay: 3000 }).show();
                })
                .catch(() => {
                    alert('Connection error occurred.');
                });
        }
    </script>
</body>

</html>