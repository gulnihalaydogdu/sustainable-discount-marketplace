<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile — BGT Market</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'DM Sans', sans-serif; background-color: #f8f4ec; }
        .navbar { background-color: #432f1f; }
        .navbar-brand {
            font-family: "Montserrat", sans-serif;
            color: #52b788 !important;
            font-size: 1.5rem;
            font-weight: 500;
        }
    </style>
</head>
<body>

    
    <nav class="navbar navbar-expand-lg navbar-dark mb-5">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/img/logo.png" alt="BGT Market Logo"
                    style="height: 50px; margin-right: 10px; object-fit: contain;">
                BGT Market
            </a>
            <div class="ms-auto d-flex gap-2">
                <span class="text-white align-self-center me-3">Hello, <strong><%= user.userName %></strong></span>
                <a href="/" class="btn btn-outline-light btn-sm">Home</a>
                <a href="/cart" class="btn btn-warning btn-sm">🛒 My Cart</a>
                <a href="/logout" class="btn btn-outline-danger btn-sm">Log Out</a>
            </div>
        </div>
    </nav>

    
    <div class="container mb-5" style="max-width: 600px;">
        <div class="card shadow-sm border-0" style="border-radius: 15px;">
            <div class="card-body p-4 p-md-5">
                <h3 class="mb-4" style="color: rgb(55, 23, 23);">⚙️ My Profile Information</h3>
                
                <% if (success) { %>
                    <div class="alert alert-success fw-bold">
                        ✅ Your profile information has been updated successfully!
                    </div>
                <% } %>

                <form action="/profile" method="POST">
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Full Name</label>
                        <input type="text" name="full_name" class="form-control form-control-lg" value="<%= consumerInfo.full_name %>" required>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label text-muted small fw-bold text-uppercase">City</label>
                            <input type="text" name="city" class="form-control form-control-lg" value="<%= consumerInfo.city %>" required>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label text-muted small fw-bold text-uppercase">District</label>
                            <input type="text" name="district" class="form-control form-control-lg" value="<%= consumerInfo.district %>" required>
                        </div>
                    </div>

                    <hr class="my-4">
                    
                    <div class="d-grid">
                        <button type="submit" class="btn btn-success btn-lg fw-bold">Save Changes</button>
                    </div>
                </form>
                
            </div>
        </div>
    </div>

</body>
</html>