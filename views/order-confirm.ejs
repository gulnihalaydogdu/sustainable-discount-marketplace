<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmation — BGT Market</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #f8f4ec;
        }

        .navbar {
            background-color: rgb(55, 23, 23);
        }

        .navbar-brand {
            font-family: 'DM Serif Display', serif;
            font-size: 1.5rem;
            color: #52b788 !important;
        }

        .success-icon {
            font-size: 5rem;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🐞 BGT Market</a>
            <div class="ms-auto d-flex gap-2">
                <a href="/" class="btn btn-outline-light btn-sm">Home</a>
                <a href="/logout" class="btn btn-outline-danger btn-sm">Log Out</a>
            </div>
        </div>
    </nav>

    <div class="container mb-5" style="max-width: 700px;">


        <div class="text-center mb-5">
            <div class="success-icon">✅</div>
            <h2 class="fw-bold mt-3" style="color: rgb(55, 23, 23);">Your Order Has Been Placed!</h2>
            <p class="text-muted">Order No: <strong>#<%= order.id %></strong></p>
            <p class="text-muted">
                <%= new Date(order.created_at).toLocaleString('en-US') %>
            </p>
        </div>


        <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead style="background-color: #f0faf5;">
                        <tr>
                            <th class="ps-4">Product</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% items.forEach(item=> { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <% if (item.image_url) { %>
                                            <img src="<%= item.image_url %>"
                                                style="width:45px; height:45px; object-fit:cover; border-radius:8px;">
                                            <% } %>
                                                <span class="fw-bold">
                                                    <%= item.name %>
                                                </span>
                                    </div>
                                </td>
                                <td>
                                    <%= item.quantity %>
                                </td>
                                <td>
                                    <%= item.unit_price %> ₺
                                </td>
                                <td class="fw-bold text-success">
                                    <%= (item.unit_price * item.quantity).toFixed(2) %> ₺
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>


        <div class="d-flex justify-content-end mb-4">
            <div class="card border-0 shadow-sm p-3" style="border-radius: 12px; min-width: 250px;">
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Grand Total</span>
                    <span class="fs-5 fw-bold text-success">
                        <%= Number(order.total_price).toFixed(2) %> ₺
                    </span>
                </div>
                <div class="d-flex justify-content-between mt-1">
                    <span class="text-muted">Status</span>
                    <span class="badge bg-warning text-dark">
                        <%= order.status %>
                    </span>
                </div>
            </div>
        </div>

        <div class="text-center">
            <a href="/" class="btn btn-success px-5 fw-bold">Continue Shopping</a>
        </div>

    </div>

</body>

</html>